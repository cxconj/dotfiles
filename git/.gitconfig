[url "ssh://git@github.com/"]
    insteadOf = https://github.com/
    insteadOf = git://github.com/
    insteadOf = git://git@github.com/
[user]
    name = cxconj
    email = 49486535+cxconj@users.noreply.github.com
    signingkey = ~/.ssh/id_ed25519.pub
[github]
    user = cxconj
[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
    hooksPath = ~/.fdev-git-hooks
[alias]
    co = checkout
[safe]
    directory = /usr/local/lib/compose-files
[gpg]
    format = ssh
[commit]
    gpgsign = true
[worktree]
    useRelativePaths = true
[init]
	defaultBranch = main
